DEEPSEEK_API_KEY=your_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
PORT=3000

# GMAIL_USER defaults to yeexianteoh1223@gmail.com (v1 mailbox); override here if needed.
GMAIL_USER=yeexianteoh1223@gmail.com
# GMAIL_APP_PASSWORD has no default — must be set. Generate one at Google Account → Security → App passwords.
GMAIL_APP_PASSWORD=your_app_password
ALLOWED_SENDERS=sender1@example.com,sender2@example.com
POLL_INTERVAL_MS=60000
ATTACHMENT_MAX_BYTES=10485760
